# 复制此文件为 .env，填入你的 API key
# cp .env.example .env

# ── AI 模型 API Keys ──
# SiliconFlow（OpenAI 兼容，用于 embedding）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
# 初始化后配置模型：
#   docker compose run --rm cli config set embedding_model openai:Qwen/Qwen3-Embedding-0.6B
#   docker compose run --rm cli config set embedding_dimensions 1024

# Anthropic Claude（用于聊天/问答，可选）
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# ── MCP OAuth 认证 ──
# 设置 MCP 服务的 admin token（32+ 字符，不设置则自动生成随机 token）
# 生成命令：head -c 32 /dev/urandom | base64 | tr -d "+/=" | head -c 48
# GBRAIN_ADMIN_BOOTSTRAP_TOKEN=your-admin-token-here-min-32-chars

# ── Postgres ──
POSTGRES_PASSWORD=gbrain
